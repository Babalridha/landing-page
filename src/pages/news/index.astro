---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { newsItems } from '../../data/news';
---

<Layout title="News & Announcements | Bab al-Ridha Institute" description="Explore the latest academic updates, course announcements, publications, and events from the Bab al-Ridha Institute.">
  <div class="min-h-screen flex flex-col selection:bg-gold selection:text-white">
    <Navbar />

    <main class="flex-grow pt-32 pb-24 bg-[#f8f6f0]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Header -->
        <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
          <div class="flex items-center justify-center space-x-4">
            <div class="h-px w-8 bg-gold-dark"></div>
            <span class="text-xs uppercase font-bold tracking-[0.3em] text-gold-dark">Latest Updates</span>
            <div class="h-px w-8 bg-gold-dark"></div>
          </div>
          <h1 class="font-serif text-5xl text-emerald-900 italic">News & <span class="not-italic">Announcements</span></h1>
          <p class="font-sans text-emerald-900/60 leading-relaxed font-light text-base md:text-lg">
            Stay informed about our latest summer courses, publications, events, and YouTube broadcasts from our dynamic departments.
          </p>
        </div>

        <!-- News Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {newsItems.map((item) => (
            <a 
              href={`/news/${item.slug}`} 
              class="group bg-white rounded-[32px] border border-gold/5 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all flex flex-col h-full overflow-hidden"
            >
              <!-- Card Image -->
              <div class="h-48 overflow-hidden relative">
                <img 
                  src={item.image} 
                  alt={item.title} 
                  class="w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-110" 
                />
                <div class="absolute inset-0 bg-emerald-950/20 mix-blend-multiply transition-opacity group-hover:opacity-0"></div>
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm p-2 rounded-lg text-emerald-950 shadow-lg">
                  {item.iconName === 'youtube' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17z"/><polygon points="10 15 15 12 10 9 10 15"/></svg>
                  )}
                  {item.iconName === 'book' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 2v18"/></svg>
                  )}
                  {item.iconName === 'graduation-cap' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/><path d="M21.5 12v6"/></svg>
                  )}
                  {item.iconName === 'map-pin' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  )}
                </div>
              </div>

              <!-- Card Body -->
              <div class="p-8 flex flex-col flex-1">
                <div class="flex items-center justify-between gap-2 mb-4 text-[10px] font-bold uppercase tracking-widest text-gold-dark opacity-60">
                  <span>{item.tag}</span>
                  <span>•</span>
                  <span>{item.date}</span>
                </div>
                
                <h3 class="font-serif text-2xl text-emerald-900 leading-snug mb-3 group-hover:text-gold transition-colors">
                  {item.title}
                </h3>
                
                {item.subtitle && (
                  <p class="text-xs text-emerald-950/40 font-medium italic mb-6 leading-relaxed">
                    {item.subtitle}
                  </p>
                )}
                
                <div class="mt-auto flex items-center text-[10px] font-bold text-gold-dark tracking-widest space-x-2">
                  <span>READ ARTICLE</span>
                  <div class="h-px w-4 bg-gold-dark transition-all group-hover:w-8"></div>
                </div>
              </div>
            </a>
          ))}
        </div>

      </div>
    </main>

    <Footer />
  </div>
</Layout>
