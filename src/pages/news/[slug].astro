---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { newsItems, type NewsItem } from '../../data/news';

export async function getStaticPaths() {
  return newsItems.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: NewsItem;
}

const { post } = Astro.props;
---

<Layout title={`${post.title} | Bab al-Ridha Institute`} description={post.subtitle || post.title}>
  <div class="min-h-screen flex flex-col selection:bg-gold selection:text-white">
    <Navbar />
    
    <main class="flex-grow pt-32 pb-24">
      <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Back Link -->
        <a 
          href="/news" 
          class="inline-flex items-center space-x-2 text-[10px] font-bold tracking-[0.25em] uppercase text-gold-dark hover:text-emerald-950 transition-colors mb-10 group"
        >
          <!-- ArrowLeft Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 transform group-hover:-translate-x-1 transition-transform"><line x1="19" x2="5" y1="12" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          <span>Back to News</span>
        </a>

        <!-- Announcement Header -->
        <div class="space-y-6 mb-12">
          <div class="flex flex-wrap items-center gap-4 text-xs font-bold uppercase tracking-wider text-gold-dark">
            <span class="bg-gold/10 px-3 py-1 rounded-full">{post.tag}</span>
            <span class="opacity-60">•</span>
            <span class="opacity-60">{post.date}</span>
            <span class="opacity-60">•</span>
            <span class="opacity-60">{post.readTime}</span>
          </div>
          
          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-emerald-950 leading-tight">
            {post.title}
          </h1>
          
          {post.subtitle && (
            <p class="font-serif text-xl md:text-2xl text-emerald-900/60 italic font-light">
              {post.subtitle}
            </p>
          )}
        </div>

        <!-- Top Image Banner -->
        <div class="relative w-full aspect-[21/9] rounded-[32px] overflow-hidden border border-gold/10 shadow-2xl mb-16">
          <img 
            src={post.image} 
            alt={post.title} 
            class="w-full h-full object-cover" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/25 to-transparent"></div>
        </div>

        <!-- Article Body -->
        <div class="prose prose-emerald prose-lg max-w-none font-sans text-emerald-900/80 leading-relaxed space-y-6">
          <Fragment set:html={post.content} />
        </div>

      </article>
    </main>

    <Footer />
  </div>
</Layout>

<style is:global>
  /* Premium typography & link spacing overrides inside post content */
  .prose p {
    font-size: 1.125rem;
    line-height: 1.85;
    color: rgba(6, 70, 53, 0.85);
  }
</style>
