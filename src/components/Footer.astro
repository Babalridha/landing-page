---
---

<footer class="bg-emerald-950 text-ivory pt-24 pb-12 relative overflow-hidden">
  <!-- Subtle decorative background -->
  <div class="absolute top-0 right-0 w-96 h-96 islamic-pattern-dark opacity-10 pointer-events-none translate-x-1/2 -translate-y-1/2"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16 mb-20">
      
      <div class="space-y-8">
        <div class="flex items-center space-x-4">
          <div class="h-16 w-auto flex items-center overflow-hidden">
            <img 
              src="https://brisc.babalridha.com/wp-content/uploads/2018/03/BRI_Logo-1.png" 
              alt="Bab al-Ridha Institute" 
              class="h-full w-auto object-contain"
            />
          </div>
          <div>
            <span class="block font-serif text-3xl font-bold tracking-tight text-ivory">BAB AL-RIDHA</span>
            <span class="block text-[8px] uppercase tracking-[0.4em] text-gold font-bold mt-1">Institute of Islamic Thought</span>
          </div>
        </div>
        
        <div class="space-y-6">
          <div class="flex items-center space-x-3">
            <div class="h-px w-6 bg-gold"></div>
            <h4 class="font-sans font-bold text-gold text-[10px] uppercase tracking-[0.3em]">Stay Connected</h4>
          </div>
          <div class="space-y-5">
            <div class="flex items-center space-x-6">
              <a href="https://www.youtube.com/@BabalRidha" target="_blank" rel="noopener noreferrer" class="text-ivory/60 hover:text-gold transition-colors flex items-center space-x-2 text-xs">
                <!-- Youtube Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17z"/><polygon points="10 15 15 12 10 9 10 15"/></svg>
                <span>YouTube</span>
              </a>
              <a href="https://www.instagram.com/babalridha/" target="_blank" rel="noopener noreferrer" class="text-ivory/60 hover:text-gold transition-colors flex items-center space-x-2 text-xs">
                <!-- Instagram Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                <span>Instagram</span>
              </a>
              <a href="#" target="_blank" rel="noopener noreferrer" class="text-ivory/60 hover:text-gold transition-colors flex items-center space-x-2 text-xs">
                <!-- MessageCircle Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                <span>WhatsApp</span>
              </a>
            </div>
            <div class="h-px w-full bg-white/5"></div>
            <div class="space-y-4 pt-2">
              <a href="tel:+1234567890" class="flex items-center space-x-3 text-ivory/60 hover:text-gold transition-colors text-xs font-medium">
                <!-- Phone Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-gold/60"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span>+1 (234) 567-890</span>
              </a>
              <a href="mailto:info@babalridha.com" class="flex items-center space-x-3 text-ivory/60 hover:text-gold transition-colors text-xs font-medium">
                <!-- Mail Icon -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-gold/60"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <span>info@babalridha.com</span>
              </a>
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="flex items-center space-x-3 mb-8">
          <div class="h-px w-6 bg-gold"></div>
          <h4 class="font-sans font-bold text-gold text-[10px] uppercase tracking-[0.3em]">Institute Units</h4>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-5">
          <ul class="space-y-4 text-xs text-ivory/60 font-medium tracking-wide">
            <li><a href="#" class="hover:text-gold transition-colors flex items-center space-x-2"><span>•</span> <span>HAWZA</span></a></li>
            <li><a href="https://brisc.babalridha.com" class="hover:text-gold transition-colors flex items-center space-x-2"><span>•</span> <span>BRISC</span></a></li>
            <li><a href="#" class="hover:text-gold transition-colors flex items-center space-x-2"><span>•</span> <span>Hawza Online</span></a></li>
          </ul>
          <ul class="space-y-4 text-xs text-ivory/60 font-medium tracking-wide">
            <li><a href="https://ahsan.babalridha.com" class="hover:text-gold transition-colors flex items-center space-x-2"><span>•</span> <span>Ahsan Program</span></a></li>
            <li><a href="#" class="hover:text-gold transition-colors flex items-center space-x-2"><span>•</span> <span>Arbaeen Backpackers (Coming Soon)</span></a></li>
            <li><a href="#" class="hover:text-gold transition-colors flex items-center space-x-2"><span>•</span> <span>BRi Kids! (Coming Soon)</span></a></li>
            <li><a href="#" class="hover:text-gold transition-colors flex items-center space-x-2"><span>•</span> <span>Lectures (Coming Soon)</span></a></li>
          </ul>
        </div>
      </div>

      <div class="bg-white/5 p-10 rounded-[40px] border border-white/10 relative overflow-hidden group">
        <div class="absolute bottom-0 right-0 p-4 opacity-5">
          <div class="w-24 h-24 text-gold rotate-12 flex items-center justify-center">
             <img src="https://brisc.babalridha.com/wp-content/uploads/2018/03/BRI_Logo-1.png" class="opacity-10" alt="bg-icon" />
          </div>
        </div>
        <h4 class="font-serif text-2xl text-gold mb-4 leading-tight italic">Support the <span class="not-italic">Journey</span></h4>
        <p class="text-xs text-ivory/60 mb-8 leading-relaxed font-light">
          Empower scholars who lead communities practically. Your support provides spiritual 
          guidance, holistic Hawzah life for students, and innovative tools for global Islamic outreach.
        </p>
        <a 
          href="/donate" 
          class="block text-center w-full bg-gold text-emerald-950 py-4 rounded-full text-xs font-bold tracking-[0.2em] hover:bg-gold-light transition-all uppercase shadow-lg cursor-pointer"
        >
          Donate
        </a>
      </div>

    </div>

    <div class="pt-12 border-t border-white/5 flex flex-col items-center justify-center">
      <p class="text-[10px] text-ivory/30 uppercase tracking-[0.4em] font-bold text-center">
        © 2026 Bab al-Ridha Institute
      </p>
    </div>
  </div>
</footer>
