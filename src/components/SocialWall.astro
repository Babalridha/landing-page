---
---

<section id="community" class="py-24 bg-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20 space-y-4">
      <div class="flex items-center justify-center space-x-4">
        <div class="h-px w-8 bg-gold-dark"></div>
        <span class="text-xs uppercase font-bold tracking-[0.3em] text-gold-dark">Digital Footprint</span>
        <div class="h-px w-8 bg-gold-dark"></div>
      </div>
      <h2 class="font-serif text-5xl text-emerald-900 italic">Stay <span class="not-italic">Connected</span></h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Online Learning Platform CTA -->
      <div class="bg-emerald-950 text-ivory p-10 rounded-[40px] flex flex-col md:flex-row items-center gap-10 group hover:shadow-2xl transition-all border border-gold/20 overflow-hidden relative">
        <div class="absolute top-0 left-0 w-32 h-32 islamic-pattern-dark opacity-10 -translate-x-1/2 -translate-y-1/2"></div>
        <div class="flex-shrink-0 bg-white/5 p-6 rounded-3xl border border-white/10">
          <!-- GraduationCap Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 text-gold"><path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/><path d="M21.5 12v6"/></svg>
        </div>
        <div class="space-y-6 text-center md:text-left relative z-10">
          <h3 class="font-serif text-3xl mb-3 leading-tight">OLP: Online Learning Platform</h3>
          <p class="font-sans text-sm text-ivory/60 leading-relaxed max-w-md">
            A curriculum of over 20+ structured courses in theology, philosophy, and history. 
            Learn at your own pace from certified scholars.
          </p>
          <button class="flex items-center space-x-3 bg-gold text-emerald-950 px-8 py-3 rounded-full font-bold text-xs uppercase tracking-widest hover:bg-gold-light transition-all w-fit mx-auto md:mx-0 shadow-lg cursor-pointer">
            <span>Join Now</span>
            <!-- ArrowUpRight Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </button>
        </div>
      </div>

      <!-- Research & Publication CTA -->
      <div class="bg-ivory border-2 border-gold/20 p-10 rounded-[40px] flex flex-col md:flex-row items-center gap-10 group hover:shadow-2xl transition-all overflow-hidden relative">
        <div class="absolute top-0 right-0 w-32 h-32 islamic-pattern-dark opacity-10 translate-x-1/2 -translate-y-1/2"></div>
        <div class="flex-shrink-0 bg-emerald-950/5 p-6 rounded-3xl border border-emerald-950/5">
          <!-- BookOpen Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 text-emerald-900"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <div class="space-y-6 text-center md:text-left relative z-10">
          <h3 class="font-serif text-3xl text-emerald-900 mb-3 leading-tight">Research & Publications</h3>
          <p class="font-sans text-sm text-emerald-950/60 leading-relaxed max-w-md">
            Critical monographs and classic text translations designed to preserve the 
            scholarly tradition for future generations.
          </p>
          <button class="flex items-center space-x-3 bg-emerald-900 text-gold px-8 py-3 rounded-full font-bold text-xs uppercase tracking-widest hover:bg-emerald-800 transition-all w-fit mx-auto md:mx-0 shadow-lg cursor-pointer">
            <span>Our Library</span>
            <!-- ArrowUpRight Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- YouTube Section -->
      <div class="relative group overflow-hidden rounded-[40px] shadow-xl h-[300px] border border-gold/10">
        <img 
          src="https://i.ytimg.com/vi/ndSxGP6isU0/maxresdefault.jpg" 
          alt="Bab al-Ridha YouTube Content" 
          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000 grayscale group-hover:grayscale-0"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-emerald-950 via-emerald-950/40 to-transparent opacity-90"></div>
        <div class="absolute inset-0 flex flex-col justify-end p-10">
          <div class="flex items-center space-x-4 mb-4">
            <div class="bg-red-600 p-2 rounded-lg">
              <!-- Youtube Icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17z"/><polygon points="10 15 15 12 10 9 10 15"/></svg>
            </div>
            <h3 class="font-serif text-3xl text-white">YouTube Channel</h3>
          </div>
          <p class="text-white/60 text-sm mb-6 max-w-sm">Watch the latest lectures, seminar archives, and short courses from the Holy Cities.</p>
          <a href="https://www.youtube.com/@BabalRidha" target="_blank" rel="noopener noreferrer" class="text-gold font-bold text-xs uppercase tracking-[0.2em] flex items-center space-x-2 group-hover:translate-x-2 transition-transform">
            <span>Subscribe</span>
            <!-- ArrowUpRight Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
        </div>
      </div>

      <!-- Instagram Section -->
      <div class="relative group overflow-hidden rounded-[40px] shadow-xl h-[300px] border border-gold/10">
        <img 
          src="https://images.unsplash.com/photo-1542810634-71277d95dcbb?auto=format&fit=crop&q=80&w=1200" 
          alt="Bab al-Ridha Instagram Content" 
          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000 grayscale group-hover:grayscale-0"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-emerald-950 via-emerald-950/40 to-transparent opacity-90"></div>
        <div class="absolute inset-0 flex flex-col justify-end p-10">
          <div class="flex items-center space-x-4 mb-4">
            <div class="bg-gradient-to-tr from-yellow-500 to-purple-600 p-2 rounded-lg">
              <!-- Instagram Icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-white"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </div>
            <h3 class="font-serif text-3xl text-white">Instagram</h3>
          </div>
          <p class="text-white/60 text-sm mb-6 max-w-sm">Visual updates from our Hawzah programs, student life, and daily scholarly reflections.</p>
          <a href="https://www.instagram.com/babalridha/" target="_blank" rel="noopener noreferrer" class="text-gold font-bold text-xs uppercase tracking-[0.2em] flex items-center space-x-2 group-hover:translate-x-2 transition-transform">
            <span>Follow Updates</span>
            <!-- ArrowUpRight Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
