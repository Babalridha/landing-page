---
---

<section id="scholarly-lens" class="relative h-[600px] bg-emerald-900 overflow-hidden flex items-center justify-center" style="--lens-width: 300px; --blur-value: 20px;">
  <!-- Modern Background -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=2000" 
      alt="Modern Cityscape" 
      class="w-full h-full object-cover opacity-30 grayscale"
    />
    <div class="absolute inset-0 flex items-center justify-center text-ivory/20 font-serif text-8xl pointer-events-none select-none uppercase tracking-tighter italic">
      Noise & Modernity
    </div>
  </div>

  <!-- The Lens Container -->
  <div 
    id="lens-container"
    class="relative z-10 bg-ivory/5 border border-gold/30 rounded-full overflow-hidden shadow-[0_0_100px_rgba(197,160,89,0.2)] transition-all duration-300 ease-out"
    style="width: var(--lens-width); height: var(--lens-width); backdrop-filter: blur(var(--blur-value)); -webkit-backdrop-filter: blur(var(--blur-value));"
  >
    <div class="absolute inset-0 flex items-center justify-center p-12 text-center">
      <div class="relative w-full h-full flex items-center justify-center">
        <img 
          src="https://images.unsplash.com/photo-1542810634-71277d95dcbb?auto=format&fit=crop&q=80&w=1000" 
          alt="Tradition Revealed" 
          class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay"
        />
        <div class="relative z-20 space-y-4">
          <h3 class="font-serif text-3xl md:text-5xl text-gold italic">Revealing Depth</h3>
          <p class="font-sans text-sm md:text-base text-ivory font-medium tracking-wide max-w-xs mx-auto">
            Our curriculum filters modern noise to reveal timeless scholarly insights.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Floating Calligraphy Particles (Decorative) -->
  <div class="absolute top-1/4 right-1/4 animate-pulse opacity-20">
    <span class="font-serif text-4xl text-gold italic">العلم</span>
  </div>
  <div class="absolute bottom-1/4 left-1/4 animate-pulse delay-700 opacity-20">
    <span class="font-serif text-4xl text-gold italic">الحكمة</span>
  </div>
</section>

<script>
  const section = document.getElementById('scholarly-lens');

  const handleScroll = () => {
    if (!section) return;
    const scrollY = window.scrollY;
    // Simple calculation for lens movement based on scroll
    const lensProgress = Math.min(Math.max((scrollY - 1500) / 1000, 0), 1);
    const lensWidth = 300 + (lensProgress * 400); // Expanding lens effect
    const blurValue = 20 - (lensProgress * 20);

    section.style.setProperty('--lens-width', `${lensWidth}px`);
    section.style.setProperty('--blur-value', `${blurValue}px`);
  };

  window.addEventListener('scroll', handleScroll, { passive: true });
  // Run on mount
  handleScroll();
</script>
